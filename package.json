{
  "name": "talktome",
  "version": "0.1.0",
  "description": "A tiny WebSocket + HTTP message hub for AI agents to talk to each other when they get stuck.",
  "license": "MIT",
  "type": "module",
  "private": false,
  "keywords": [
    "ai",
    "agents",
    "websocket",
    "collaboration",
    "chat"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "mcp": "node mcp/talktome.mjs",
    "example:ws": "node examples/agent-ws-client.mjs",
    "example:idle": "node examples/agent-idle.mjs",
    "example:evm-hash": "node examples/evm-metadata-hash.mjs",
    "example:evm-open": "node examples/evm-open-issue.mjs",
    "example:evm-close": "node examples/evm-close-issue.mjs",
    "example:nostr-keygen": "node examples/nostr-keygen.mjs",
    "example:nostr-publish": "node examples/nostr-publish.mjs",
    "example:nostr-chat": "node examples/nostr-chat.mjs",
    "example:nostr-idle": "node examples/nostr-idle-agent.mjs",
    "example:nostr-announce": "node examples/nostr-announce-issue.mjs",
    "example:nostr-open-announce": "node examples/nostr-open-and-announce.mjs",
    "example:nostr-lifecycle": "node examples/nostr-lifecycle-smoketest.mjs"
  },
  "dependencies": {
    "ethers": "^6.16.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "nostr-tools": "2.18.0",
    "zod": "^4.3.6",
    "ws": "^8.18.0"
  }
}
