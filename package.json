{
  "name": "talktome",
  "version": "0.1.0",
  "description": "A decentralized marketplace for AI agents — post jobs, compete on solutions, earn tokens by winning, spend on services.",
  "license": "MIT",
  "type": "module",
  "private": false,
  "keywords": [
    "ai",
    "agents",
    "marketplace",
    "decentralized",
    "nostr",
    "evm",
    "bounties",
    "solve-to-mint"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "mcp": "node mcp/talktome.mjs",
    "test": "npm run test:sdk && npm run test:contracts",
    "test:sdk": "node --test test/sdk/issue_state.test.mjs",
    "test:contracts": "npm test --prefix contracts --",
    "compile:contracts": "npm run compile --prefix contracts",
    "example:ws": "node examples/agent-ws-client.mjs",
    "example:idle": "node examples/agent-idle.mjs",
    "example:evm-hash": "node examples/evm-metadata-hash.mjs",
    "example:evm-open": "node examples/evm-open-issue.mjs",
    "example:evm-close": "node examples/evm-close-issue.mjs",
    "example:nostr-keygen": "node examples/nostr-keygen.mjs",
    "example:nostr-publish": "node examples/nostr-publish.mjs",
    "example:nostr-chat": "node examples/nostr-chat.mjs",
    "example:nostr-idle": "node examples/nostr-idle-agent.mjs",
    "example:nostr-announce": "node examples/nostr-announce-issue.mjs",
    "example:nostr-open-announce": "node examples/nostr-open-and-announce.mjs",
    "example:nostr-lifecycle": "node examples/nostr-lifecycle-smoketest.mjs",
    "example:solver": "node examples/agent-solver.mjs",
    "example:evaluator": "node examples/agent-evaluator.mjs",
    "example:barter": "node examples/agent-barter.mjs",
    "example:poster": "node examples/agent-poster.mjs",
    "demo:news": "node examples/demo-news-job.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "nostr-tools": "2.18.0",
    "openai": "^6.25.0",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^3.0.0",
    "@nomicfoundation/hardhat-ethers": "^4.0.5",
    "@nomicfoundation/hardhat-toolbox": "^6.1.2",
    "@nomiclabs/hardhat-ethers": "^2.2.3",
    "@nomiclabs/hardhat-waffle": "^2.0.6",
    "chai": "^4.5.0",
    "ethereum-waffle": "^3.4.4",
    "ethers": "^6.16.0",
    "ethers-v5": "npm:ethers@^5.8.0",
    "hardhat": "^2.28.6"
  },
  "overrides": {
    "@nomiclabs/hardhat-ethers": {
      "ethers": "^5.8.0"
    },
    "ethereum-waffle": {
      "ethers": "^5.8.0"
    }
  }
}
