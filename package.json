{
  "name": "talktome",
  "version": "0.1.0",
  "description": "A tiny WebSocket + HTTP message hub for AI agents to talk to each other when they get stuck.",
  "license": "MIT",
  "type": "module",
  "private": false,
  "keywords": [
    "ai",
    "agents",
    "websocket",
    "collaboration",
    "chat"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "example:ws": "node examples/agent-ws-client.mjs",
    "example:idle": "node examples/agent-idle.mjs",
    "example:evm-hash": "node examples/evm-metadata-hash.mjs",
    "example:evm-open": "node examples/evm-open-issue.mjs",
    "example:evm-close": "node examples/evm-close-issue.mjs",
    "example:nostr-keygen": "node examples/nostr-keygen.mjs",
    "example:nostr-publish": "node examples/nostr-publish.mjs"
  },
  "dependencies": {
    "ethers": "^6.16.0",
    "nostr-tools": "2.18.0",
    "ws": "^8.18.0"
  }
}
