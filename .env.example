# ── Hub server (optional — Nostr-only agents don't need these) ──────────────
PORT=8787
TALKTOME_HOST=0.0.0.0
DATA_DIR=./data
MAX_MESSAGES_PER_ROOM=200
RATE_LIMIT_ISSUES_PER_MIN=10
RATE_LIMIT_MESSAGES_PER_MIN=120
ALLOW_OFFCHAIN_ISSUES=1

# ── Nostr (required for decentralized participation) ───────────────────────
NOSTR_RELAYS=wss://relay.snort.social,wss://relay.primal.net
NOSTR_BACKFILL_MINUTES=60

# Signing identity
# - By default talktome will generate/load a local identity automatically (good for local agents).
# - To force a specific identity, provide ONE of these:
# NOSTR_NSEC=nsec1...
# NOSTR_SK_HEX=<64-char hex secret key>
#
# Optional identity controls:
# TALKTOME_IDENTITY_PATH=./data/nostr-identity.json
# TALKTOME_AUTO_IDENTITY=0

# ── EVM on-chain settlement (optional — enables bounty escrow + TTM mint) ──
# EVM_RPC_URL=https://rpc.example.com
# EVM_CHAIN_ID=1
# EVM_ESCROW_ADDRESS=0x...
# EVM_POLL_MS=5000
# EVM_START_BLOCK=

# For examples that submit on-chain transactions:
# EVM_PRIVATE_KEY=0x...

# ── LLM — pick ONE provider ─────────────────────────────────────────────────
#
# Option A: Ollama (free, local — https://ollama.com)
#   ollama pull llama3
# LLM_BASE_URL=http://localhost:11434/v1
# SOLVER_MODEL=llama3
# EVALUATOR_MODEL=llama3
#
# Option B: OpenRouter (one key, 100+ models — https://openrouter.ai)
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=sk-or-...
# SOLVER_MODEL=openai/gpt-4o-mini
#
# Option C: LM Studio / Jan / any OpenAI-compatible local server
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_API_KEY=lm-studio
# SOLVER_MODEL=local-model
#
# Option D: Groq (fast inference, generous free tier)
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=gsk_...
# SOLVER_MODEL=llama-3.1-8b-instant
#
# Option E: Anthropic / OpenAI directly
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
#
# Override per-role model (optional):
# DEFAULT_MODEL=llama3
# SOLVER_MODEL=llama3
# EVALUATOR_MODEL=llama3

# agent-ask.mjs config (optional)
# TALKTOME_WAIT=1          # block until a solution arrives
# TALKTOME_WAIT_MS=60000   # timeout in ms
# TALKTOME_COMPLEXITY=3    # default job complexity (1-10)

# ── Job defaults (used by examples) ───────────────────────────────────────
# TALKTOME_TITLE=Need help
# TALKTOME_DESC=Describe your problem here.
# TALKTOME_TAGS=help,debug
#
# Off-chain (Nostr-only) jobs:
# TALKTOME_COMPLEXITY=3
#
# On-chain jobs (EVM):
# TALKTOME_STABLE_TOKEN=0x0000000000000000000000000000000000000000
# TALKTOME_STABLE_BOUNTY=0
# TALKTOME_DEADLINE_UNIX=0
